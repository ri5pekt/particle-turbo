# Hoist all @medusajs/* packages to the workspace root node_modules.
# Without this, Vite (used by the Medusa admin dev server) cannot resolve
# transitive @medusajs/* deps (e.g. @medusajs/draft-order/admin auto-imported
# in .medusa/client/entry.jsx) because pnpm only symlinks direct deps into
# each app's node_modules by default.
public-hoist-pattern[]=@medusajs/*
public-hoist-pattern[]=react
public-hoist-pattern[]=react-dom
public-hoist-pattern[]=react-router-dom
public-hoist-pattern[]=react-router
