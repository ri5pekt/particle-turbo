{
  "kind": "singleType",
  "collectionName": "site_setting",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Settings",
    "description": "Global site configuration: logo, favicon, default SEO, social links, contact info. One entry only."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "site_name": {
      "type": "string",
      "required": true,
      "default": "Particle For Men"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "required": true
    },
    "logo_dark": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "favicon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "default_seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo",
      "description": "Fallback SEO used on pages that do not have their own SEO component"
    },
    "social_facebook": {
      "type": "string"
    },
    "social_instagram": {
      "type": "string"
    },
    "social_twitter": {
      "type": "string"
    },
    "social_youtube": {
      "type": "string"
    },
    "social_tiktok": {
      "type": "string"
    },
    "contact_email": {
      "type": "email"
    },
    "contact_phone": {
      "type": "string"
    },
    "announcement_bar_text": {
      "type": "string",
      "description": "Text shown in the top announcement bar. Leave blank to hide."
    },
    "announcement_bar_link": {
      "type": "component",
      "repeatable": false,
      "component": "shared.link"
    }
  }
}
