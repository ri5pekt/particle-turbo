{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Editorial product content. Joined to Medusa by matching handle. Editors add SEO, sections, and rich description here."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "handle": {
      "type": "string",
      "unique": true
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "sections.hero",
        "sections.text-image",
        "sections.benefits",
        "sections.testimonials",
        "sections.faq",
        "sections.rich-text",
        "sections.cta-banner",
        "sections.video",
        "sections.before-after",
        "sections.how-to-use",
        "sections.ingredients",
        "sections.product-showcase"
      ]
    }
  }
}
