{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Editorial product content. Editors add SEO, PDP sections, media, and rich description here."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "handle": {
      "type": "string",
      "unique": true
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "hero": {
      "type": "component",
      "repeatable": false,
      "component": "sections.hero"
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "pdp.page-header",
        "pdp.scroll-tabs",
        "pdp.banner-section",
        "pdp.horizontal-accordion",
        "pdp.price-section",
        "pdp.carousel-section",
        "pdp.add-to-cart-regular",
        "pdp.add-to-cart-tabs",
        "pdp.ingredients-accordion",
        "pdp.reviews-carousel",
        "pdp.stamped-reviews",
        "pdp.more-products"
      ]
    }
  }
}
