{
  "kind": "collectionType",
  "collectionName": "landing_pages",
  "info": {
    "singularName": "landing-page",
    "pluralName": "landing-pages",
    "displayName": "Landing Page",
    "description": "Campaign and marketing landing pages. URL: /lpage/[slug]. Each LP controls its own header/footer visibility."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "required": true,
      "targetField": "title"
    },
    "title": {
      "type": "string",
      "required": true
    },
    "template": {
      "type": "enumeration",
      "enum": [
        "default",
        "product-launch",
        "brand-story",
        "promotional",
        "advertorial",
        "quiz-funnel"
      ],
      "default": "default",
      "description": "Template tag for editorial organisation. Landing pages use their own section components via the Dynamic Zone."
    },
    "show_header": {
      "type": "boolean",
      "default": true
    },
    "show_footer": {
      "type": "boolean",
      "default": true
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "landing.advertorial-hero",
        "landing.reason-list",
        "landing.video-block",
        "landing.sale-offer",
        "landing.reviews-anchor"
      ]
    }
  }
}
