{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Particle Magazine blog posts. URL: /blog/[slug] or /blog/[category]/[slug]"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "required": true,
      "targetField": "title"
    },
    "title": {
      "type": "string",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "description": "Short summary shown in article cards and meta description fallback"
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "required": true
    },
    "body": {
      "type": "richtext",
      "required": true
    },
    "author": {
      "type": "string"
    },
    "author_avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "reading_time_minutes": {
      "type": "integer"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::article-category.article-category",
      "inversedBy": "articles"
    },
    "related_articles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::article.article"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
