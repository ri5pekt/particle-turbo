{
  "collectionName": "components_sections_text_images",
  "info": {
    "displayName": "Text + Image",
    "icon": "landscape",
    "description": "Side-by-side text block and image, with layout toggle"
  },
  "options": {},
  "attributes": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "ab_test_key": {
      "type": "string"
    },
    "ab_test_value": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "body": {
      "type": "richtext",
      "required": true
    },
    "cta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.link"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "required": true
    },
    "layout": {
      "type": "enumeration",
      "enum": ["image_left", "image_right"],
      "default": "image_right"
    }
  }
}
