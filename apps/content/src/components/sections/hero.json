{
  "collectionName": "components_sections_heroes",
  "info": {
    "displayName": "Hero",
    "icon": "landscape",
    "description": "Full-width hero banner with headline, subheadline, CTA, and background image or video"
  },
  "options": {},
  "attributes": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "ab_test_key": {
      "type": "string"
    },
    "ab_test_value": {
      "type": "string"
    },
    "headline": {
      "type": "richtext",
      "required": true
    },
    "subheadline": {
      "type": "text"
    },
    "cta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.link"
    },
    "cta_secondary": {
      "type": "component",
      "repeatable": false,
      "component": "shared.link"
    },
    "background_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "background_video_url": {
      "type": "string"
    },
    "overlay_opacity": {
      "type": "integer"
    },
    "text_align": {
      "type": "enumeration",
      "enum": ["left", "center", "right"],
      "default": "center"
    }
  }
}
