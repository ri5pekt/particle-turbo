{
  "collectionName": "components_sections_heroes",
  "info": {
    "displayName": "Hero",
    "icon": "landscape",
    "description": "Full-width hero banner with headline, CTA, and background image or video"
  },
  "options": {},
  "attributes": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "headline": {
      "type": "text",
      "required": true,
      "description": "Plain text field — HTML tags are allowed (e.g. <strong>, <span>)."
    },
    "cta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.link"
    },
    "background_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "background_video": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["videos"],
      "description": "Desktop background video (mp4 recommended)."
    },
    "mobile_video": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["videos"],
      "description": "Mobile background video. Upload a portrait-cropped version for small screens."
    },
    "overlay_opacity": {
      "type": "integer",
      "description": "Dark overlay strength 0–100 over the background."
    },
    "text_align": {
      "type": "enumeration",
      "enum": ["left", "center", "right"],
      "default": "center"
    }
  }
}
