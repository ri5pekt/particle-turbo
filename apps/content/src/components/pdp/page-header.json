{
  "collectionName": "components_pdp_page_headers",
  "info": {
    "displayName": "Page Header",
    "icon": "crown",
    "description": "Full-screen PDP header with background video or image, title, rating, copy, and CTA."
  },
  "options": {},
  "attributes": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "theme": {
      "type": "enumeration",
      "enum": ["gravite", "varros"],
      "default": "gravite"
    },
    "title": {
      "type": "string",
      "required": true
    },
    "rating_label": {
      "type": "string"
    },
    "rating_value": {
      "type": "decimal"
    },
    "rating_percent": {
      "type": "decimal",
      "default": 100
    },
    "body": {
      "type": "richtext"
    },
    "cta_label": {
      "type": "string"
    },
    "cta_href": {
      "type": "string"
    },
    "background_video_url": {
      "type": "string"
    },
    "background_image_url": {
      "type": "string"
    },
    "background_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    }
  }
}
