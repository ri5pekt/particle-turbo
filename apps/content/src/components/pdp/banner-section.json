{
  "collectionName": "components_pdp_banner_sections",
  "info": {
    "displayName": "Banner Section",
    "icon": "landscape",
    "description": "Gravite image banner with title and rich text overlay."
  },
  "options": {},
  "attributes": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "theme": {
      "type": "enumeration",
      "enum": ["gravite", "varros"],
      "default": "gravite"
    },
    "title": {
      "type": "string",
      "required": true
    },
    "body": {
      "type": "richtext"
    },
    "background_image_url": {
      "type": "string",
      "required": true
    },
    "background_image_alt": {
      "type": "string"
    },
    "background_image_mobile_url": {
      "type": "string"
    },
    "background_image_mobile_alt": {
      "type": "string"
    },
    "content_position": {
      "type": "enumeration",
      "enum": ["top", "bottom"],
      "default": "top"
    }
  }
}
