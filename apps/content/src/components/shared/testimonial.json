{
  "collectionName": "components_shared_testimonials",
  "info": {
    "displayName": "Testimonial",
    "icon": "quote",
    "description": "A customer review or quote"
  },
  "options": {},
  "attributes": {
    "quote": {
      "type": "text",
      "required": true
    },
    "author": {
      "type": "string",
      "required": true
    },
    "role": {
      "type": "string"
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "rating": {
      "type": "integer"
    },
    "verified": {
      "type": "boolean",
      "default": false
    }
  }
}
