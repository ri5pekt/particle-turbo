# =============================================================================
# particle-turbo — environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL — Commerce (Medusa)
# Port: 5432
# -----------------------------------------------------------------------------
POSTGRES_COMMERCE_USER=medusa
POSTGRES_COMMERCE_PASSWORD=medusa_secret
POSTGRES_COMMERCE_DB=medusa_db

# -----------------------------------------------------------------------------
# PostgreSQL — Content (Strapi)
# Port: 5433
# -----------------------------------------------------------------------------
POSTGRES_CONTENT_USER=strapi
POSTGRES_CONTENT_PASSWORD=strapi_secret
POSTGRES_CONTENT_DB=strapi_db

# -----------------------------------------------------------------------------
# Redis
# Port: 6379
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Medusa v2 — Commerce app
# Full postgres connection string (uses the commerce DB above)
# -----------------------------------------------------------------------------
MEDUSA_DATABASE_URL=postgres://medusa:medusa_secret@postgres-commerce:5432/medusa_db
MEDUSA_REDIS_URL=redis://redis:6379

# Generate with: openssl rand -base64 32
MEDUSA_JWT_SECRET=change-me-jwt-secret
MEDUSA_COOKIE_SECRET=change-me-cookie-secret

# Initial admin user created on first seed
MEDUSA_ADMIN_EMAIL=admin@example.com
MEDUSA_ADMIN_PASSWORD=change-me-admin-password

# -----------------------------------------------------------------------------
# Strapi v5 — Content app
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
STRAPI_JWT_SECRET=change-me-strapi-jwt-secret
STRAPI_ADMIN_JWT_SECRET=change-me-strapi-admin-jwt-secret

# Generate with: openssl rand -base64 16
STRAPI_API_TOKEN_SALT=change-me-api-token-salt

# Comma-separated list of secrets — generate 4x: openssl rand -base64 32
STRAPI_APP_KEYS=change-me-key-1,change-me-key-2,change-me-key-3,change-me-key-4

# -----------------------------------------------------------------------------
# Nuxt 3 — Storefront
# Internal Docker network URLs (service-to-service)
# -----------------------------------------------------------------------------
NUXT_PUBLIC_MEDUSA_URL=http://commerce:9000
NUXT_PUBLIC_STRAPI_URL=http://content:1337

# Medusa publishable API key (create in Medusa admin → Settings → Publishable API keys)
NUXT_MEDUSA_API_KEY=

# Strapi read-only token for editorial content (create in Strapi admin → Settings → API Tokens)
# Scope: read-only. Used by Nuxt server routes to fetch pages, blog posts, navigation, etc.
# Nuxt joins Strapi editorial data with Medusa commerce data using product handle as the shared key.
NUXT_STRAPI_API_TOKEN=

# Medusa CORS — browser-visible URLs allowed to call Medusa API
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:9000,http://localhost:3000

# Strapi auto-admin — used only on first boot to create the first superadmin
# Leave blank to register manually at /admin
STRAPI_ADMIN_EMAIL=
STRAPI_ADMIN_INITIAL_PASSWORD=

# Strapi server
CORS_ORIGIN=http://localhost:3000,http://localhost:9000
HOST=0.0.0.0
PORT=1337
